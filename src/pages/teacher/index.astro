---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const units = (await getCollection('units')).sort((a, b) => a.data.order - b.data.order);
const base = import.meta.env.BASE_URL;

const unitColors: Record<string, string> = {
  'matter':           'border-l-cyan-600',
  'forces':           'border-l-violet-600',
  'living-systems':   'border-l-emerald-600',
  'climate':          'border-l-amber-500',
  'energy-resources': 'border-l-orange-500',
  'space':            'border-l-indigo-600',
};
---

<BaseLayout title="Teacher Hub" teacherMode={true}>
  <div class="mb-8">
    <p class="text-xs font-bold uppercase tracking-widest text-teacher-600 mb-2">Teacher Hub</p>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">All Units — Teacher View</h1>
    <p class="text-slate-500">Lesson guides, Socratic prompts, misconception flags, and timing notes.</p>
  </div>

  <div class="space-y-3">
    {units.map(unit => (
      <a
        href={`${base}teacher/${unit.slug}`}
        class={`flex items-center gap-4 bg-white rounded-xl border border-slate-200 border-l-4 ${unitColors[unit.slug] ?? 'border-l-slate-400'} px-5 py-4 hover:shadow-md transition-shadow group`}
      >
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Unit {unit.data.order}</span>
            <span class="text-xs font-semibold bg-teacher-100 text-teacher-800 px-2 py-0.5 rounded-full">
              Tier {unit.data.tier}
            </span>
          </div>
          <p class="font-bold text-slate-900 group-hover:text-science-700 transition-colors">
            {unit.data.title}
          </p>
          <p class="text-xs text-slate-400 italic mt-0.5">{unit.data.guidingQuestion}</p>
        </div>
        <svg class="w-5 h-5 text-slate-300 group-hover:text-science-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ))}
  </div>
</BaseLayout>
