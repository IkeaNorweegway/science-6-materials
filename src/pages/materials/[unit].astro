---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  return [
    { params: { unit: 'matter' } },
    { params: { unit: 'forces' } },
    { params: { unit: 'living-systems' } },
    { params: { unit: 'climate' } },
    { params: { unit: 'energy-resources' } },
    { params: { unit: 'space' } },
    { params: { unit: 'year-review' } },
  ];
}

const { unit } = Astro.params;

type MaterialFile = { label: string; badge?: string; badgeStyle?: string; href: string };
type Section = { heading: string; items: MaterialFile[] };

interface UnitData {
  label: string;
  tagline: string;
  border: string;
  text: string;
  bg: string;
  accentText: string;
  sections: Section[];
  answerKeys: MaterialFile[];
}

const b = base;

