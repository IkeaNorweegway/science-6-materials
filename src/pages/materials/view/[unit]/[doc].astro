---
import Nav from '../../../../components/Nav.astro';
const base = import.meta.env.BASE_URL;

export function getStaticPaths() {
  const unitFiles: Record<string, string[]> = {
    matter: [
      'sci6-matter-notes-v1', 'sci6-matter-notes-ef-v1', 'sci6-matter-notes-fr-v1',
      'sci6-matter-workbook-v1', 'sci6-matter-workbook-ef-v1', 'sci6-matter-workbook-fr-v1',
      'sci6-matter-notes-answers-v1', 'sci6-matter-workbook-answers-v1', 'sci6-matter-workbook-ef-answers-v1',
    ],
    forces: [
      'sci6-forces-notes-v1', 'sci6-forces-notes-ef-v1', 'sci6-forces-notes-fr-v1',
      'sci6-forces-workbook-v1', 'sci6-forces-workbook-ef-v1', 'sci6-forces-workbook-fr-v1',
      'sci6-forces-notes-answers-v1', 'sci6-forces-workbook-answers-v1', 'sci6-forces-workbook-ef-answers-v1',
    ],
    'living-systems': [
      'sci6-living-systems-notes-gr6-v1', 'sci6-living-systems-notes-ef-gr6-v1', 'sci6-living-systems-notes-fr-v1',
      'sci6-living-systems-workbook-gr6-v1', 'sci6-living-systems-workbook-ef-v1', 'sci6-living-systems-workbook-fr-v1',
      'sci6-living-systems-notes-answers-v1', 'sci6-living-systems-workbook-answers-v1', 'sci6-living-systems-workbook-ef-answers-v1',
    ],
    climate: [
      'sci6-climate-notes-v1', 'sci6-climate-notes-ef-v1', 'sci6-climate-notes-fr-v1',
      'sci6-climate-workbook-v1', 'sci6-climate-workbook-ef-v1', 'sci6-climate-workbook-fr-v1',
      'sci6-climate-notes-answers-v1', 'sci6-climate-workbook-answers-v1', 'sci6-climate-workbook-ef-answers-v1',
    ],
    'energy-resources': [
      'sci6-energy-resources-notes-v1', 'sci6-energy-resources-notes-ef-v1', 'sci6-energy-resources-notes-fr-v1',
      'sci6-energy-resources-workbook-v1', 'sci6-energy-resources-workbook-ef-v1', 'sci6-energy-resources-workbook-fr-v1',
      'sci6-energy-resources-notes-answers-v1', 'sci6-energy-resources-workbook-answers-v1', 'sci6-energy-resources-workbook-ef-answers-v1',
    ],
    space: [
      'sci6-space-notes-v1', 'sci6-space-notes-ef-v1', 'sci6-space-notes-fr-v1',
      'sci6-space-workbook-v1', 'sci6-space-workbook-ef-v1', 'sci6-space-workbook-fr-v1',
      'sci6-space-notes-answers-v1', 'sci6-space-workbook-answers-v1', 'sci6-space-workbook-ef-answers-v1',
    ],
    'year-review': [
      'sci6-year-notes-v1', 'sci6-year-notes-ef-v1', 'sci6-year-notes-fr-v1',
      'sci6-year-review-workbook-gr6-v1', 'sci6-year-review-workbook-ef-v1', 'sci6-year-review-workbook-fr-v1',
      'sci6-year-review-workbook-answers-v1', 'sci6-year-review-workbook-ef-answers-v1',
    ],
    fr: [
      'sci6-year-notes-fr-v1',
      'sci6-matter-notes-fr-v1', 'sci6-forces-notes-fr-v1', 'sci6-living-systems-notes-fr-v1',
      'sci6-climate-notes-fr-v1', 'sci6-energy-resources-notes-fr-v1', 'sci6-space-notes-fr-v1',
      'sci6-year-review-workbook-fr-v1',
      'sci6-matter-workbook-fr-v1', 'sci6-forces-workbook-fr-v1', 'sci6-living-systems-workbook-fr-v1',
      'sci6-climate-workbook-fr-v1', 'sci6-energy-resources-workbook-fr-v1', 'sci6-space-workbook-fr-v1',
    ],
  };

  const paths: { params: { unit: string; doc: string } }[] = [];
  for (const [unit, files] of Object.entries(unitFiles)) {
    for (const doc of files) {
      paths.push({ params: { unit, doc } });
    }
  }
  return paths;
}

const { unit, doc } = Astro.params;

const unitLabels: Record<string, string> = {
  matter: 'Matter',
  forces: 'Forces',
  'living-systems': 'Living Systems',
  climate: 'Climate',
  'energy-resources': 'Energy Resources',
  space: 'Space',
  'year-review': 'Year Review',
  fr: 'Matériaux français',
};

const backHref = unit === 'fr' ? `${base}materials/fr` : `${base}materials/${unit}`;
const backLabel = `← ${unitLabels[unit] ?? 'Materials'}`;
const fileUrl = `${base}materials/${doc}.html`;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{unitLabels[unit] ?? unit} — {doc} | Grade 6 Science</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <style>
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow: hidden;
    }
    .viewer-shell {
      display: flex;
      flex-direction: column;
      height: 100vh;
    }
    .back-bar {
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
      padding: 0.4rem 1.25rem;
      flex-shrink: 0;
    }
    .back-bar a {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 0.8rem;
      color: #64748b;
      text-decoration: none;
    }
    .back-bar a:hover { color: #0f172a; }
    .doc-frame {
      flex: 1;
      border: none;
      width: 100%;
      display: block;
    }
    @media print {
      .viewer-nav, .back-bar { display: none !important; }
      .doc-frame { height: 100vh; }
    }
  </style>
</head>
<body>
  <div class="viewer-shell">
    <div class="viewer-nav">
      <Nav />
    </div>
    <div class="back-bar">
      <a href={backHref}>{backLabel}</a>
    </div>
    <iframe
      src={fileUrl}
      class="doc-frame"
      title={doc}
    />
  </div>
</body>
</html>
