  {
    title: 'Matter — Easy Read Workbook',
    description: 'Same 30 questions as the standard Matter workbook, rewritten at an easy-read level. Short sentences, word banks on every question, and hint boxes on all Core questions.',
    unit: 'matter',
    unitLabel: 'Matter',
    href: `${base}materials/sci6-matter-workbook-ef-v1.html`,
