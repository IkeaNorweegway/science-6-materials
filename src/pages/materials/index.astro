---

<BaseLayout title="Materials">
  <div class="mb-10">
    <p class="text-xs font-bold uppercase tracking-widest text-science-600 mb-2">Grade 6 Science</p>
    <h1 class="text-4xl font-bold text-slate-900 mb-3">Materials</h1>
    <p class="text-slate-500 text-lg max-w-xl">
      Print-ready classroom materials. Open in the browser or download to print.
    </p>
  </div>

  <!-- Notes Packages -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-4">Notes Packages</h2>
    <div class="space-y-3">
      {notes.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
                {m.level && (
                  <span class="text-xs text-slate-400 font-medium">{m.level}</span>
                )}
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Teacher Delivery Guides -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-1">Teacher Delivery Guides</h2>
    <p class="text-xs text-slate-400 mb-4">SHOW/SAY/CUE scripts — teacher copy only</p>
    <div class="space-y-3">
      {teacherNotes.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-800 text-white tracking-wide">Teacher Copy</span>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Workbooks -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-4">Workbooks</h2>
    <div class="space-y-3">
      {workbooks.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>
  <!-- Easy Read Workbooks -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-1">Easy Read Workbooks</h2>
    <p class="text-xs text-slate-400 mb-4">Same questions as standard workbooks — simplified language, word banks on every question, hint boxes throughout</p>
    <div class="space-y-3">
      {workbooksEF.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-sky-100 text-sky-800 tracking-wide">Easy Read</span>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Notes Answer Keys -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-1">Answer Keys — Notes</h2>
    <p class="text-xs text-slate-400 mb-4">Fill-in blank answers for the guided notes packages — teacher copy only</p>
    <div class="space-y-3">
      {notesAnswerKeys.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-800 text-white tracking-wide">Teacher Copy</span>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Workbook Answer Keys -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-1">Answer Keys — Workbooks</h2>
    <p class="text-xs text-slate-400 mb-4">Full marking guides for all workbooks — teacher copy only</p>
    <div class="space-y-3">
      {workbookAnswerKeys.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-slate-800 text-white tracking-wide">Teacher Copy</span>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
