    unit: 'living-systems',
    unitLabel: 'Living Systems',
    href: `${base}materials/sci6-living-systems-workbook-ef-v1.html`,
  },
  {
    title: 'Climate — Easy Read Workbook',
    description: 'Same 30 questions as the standard Climate workbook, rewritten at an easy-read level. Word banks on every question, hint boxes on all Core questions.',
    unit: 'climate',
    unitLabel: 'Climate',
    href: `${base}materials/sci6-climate-workbook-ef-v1.html`,
  },
  {
    title: 'Energy Resources — Easy Read Workbook',
    description: 'Same 24 questions as the standard Energy Resources workbook, rewritten at an easy-read level. Word banks on every question, hint boxes on all Core questions.',
    unit: 'energy-resources',
    unitLabel: 'Energy Resources',
    href: `${base}materials/sci6-energy-resources-workbook-ef-v1.html`,
