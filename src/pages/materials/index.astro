---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const unitColors: Record<string, { bg: string; text: string; border: string }> = {
  matter:             { bg: 'bg-cyan-50',    text: 'text-cyan-800',    border: 'border-cyan-400' },
  forces:             { bg: 'bg-violet-50',  text: 'text-violet-800',  border: 'border-violet-400' },
  'living-systems':   { bg: 'bg-emerald-50', text: 'text-emerald-800', border: 'border-emerald-400' },
  climate:            { bg: 'bg-amber-50',   text: 'text-amber-800',   border: 'border-amber-400' },
  'energy-resources': { bg: 'bg-orange-50',  text: 'text-orange-800',  border: 'border-orange-400' },
  space:              { bg: 'bg-indigo-50',  text: 'text-indigo-800',  border: 'border-indigo-400' },
  'all-units':        { bg: 'bg-science-50', text: 'text-science-800', border: 'border-science-400' },
};

const notes = [
  {
    title: 'Year Notes — Standard',
    description: 'Guided fill-in notes covering all six units. Two-column layout with vocab and misconception callouts in the margin.',
    unit: 'all-units',
    unitLabel: 'All Units',
    level: 'Grade 6',
    href: `${base}materials/sci6-year-notes-v1.html`,
  },
  {
    title: 'Year Notes — Easy Read',
    description: 'Same content at an E–F reading level. Short sentences, generous white space, vocab defined immediately in the margin.',
    unit: 'all-units',
    unitLabel: 'All Units',
    level: 'E–F Level',
    href: `${base}materials/sci6-year-notes-ef-v1.html`,
  },
  {
    title: 'Matter — Guided Notes',
    description: 'Full unit notes package for Matter. Particle model, states, phase changes, thermometers, expansion/contraction, and the water anomaly.',
    unit: 'matter',
    unitLabel: 'Matter',
    href: `${base}materials/sci6-matter-notes-v1.html`,
  },
  {
    title: 'Matter — Easy Read Notes',
    description: 'Easy Read version. 70/30 layout, EF reading level, vocab callouts, misconception warnings, and key reminders in the sidebar. Designed for students who need lower text demand.',
    unit: 'matter',
    unitLabel: 'Matter',
    level: 'Easy Read',
    href: `${base}materials/sci6-matter-notes-ef-v1.html`,
  },
  {
    title: 'Forces — Guided Notes',
    description: 'Full unit notes for Forces. Force arrows/diagrams, external forces (applied, friction, elastic), internal forces (tension, compression, shear, torsion), plasticity/elasticity, and Newton\'s Third Law.',
    unit: 'forces',
    unitLabel: 'Forces',
    href: `${base}materials/sci6-forces-notes-v1.html`,
  },
  {
    title: 'Forces — Easy Read Notes',
    description: 'Easy Read version. 70/30 layout, EF reading level. Covers all five sections with vocab callouts, misconception warnings, and key reminders in the sidebar.',
    unit: 'forces',
    unitLabel: 'Forces',
    level: 'Easy Read',
    href: `${base}materials/sci6-forces-notes-ef-v1.html`,
  },
  {
    title: 'Living Systems — Guided Notes',
    description: 'Full unit notes for Living Systems. Biotic/abiotic, photosynthesis (including soil misconception), plant-animal interdependence, trophic cascades, FNMI sacred plants, and CS conditional logic.',
    unit: 'living-systems',
    unitLabel: 'Living Systems',
    href: `${base}materials/sci6-living-systems-notes-gr6-v1.html`,
  },
  {
    title: 'Living Systems — Easy Read Notes',
    description: 'Easy Read version. 70/30 layout, EF reading level. Biotic/abiotic, photosynthesis, food webs, trophic cascades, and Indigenous ecological knowledge — with vocab callouts and misconception warnings.',
    unit: 'living-systems',
    unitLabel: 'Living Systems',
    level: 'Easy Read',
    href: `${base}materials/sci6-living-systems-notes-ef-gr6-v1.html`,
  },
  {
    title: 'Climate — Guided Notes',
    description: 'Full unit notes for Climate. Weather vs. climate, greenhouse effect, geographic factors, albedo, natural and human causes, Alberta effects (wildfires, glaciers, FNMI impacts), measurement tools, Traditional Ecological Knowledge, and climate models as CS abstractions.',
    unit: 'climate',
    unitLabel: 'Climate',
    href: `${base}materials/sci6-climate-notes-v1.html`,
  },
  {
    title: 'Climate — Easy Read Notes',
    description: 'Easy Read version. 70/30 layout, EF reading level. Weather vs. climate, greenhouse effect, causes of climate change, Alberta effects, and the role of Indigenous Knowledge Keepers — with vocab callouts and misconception warnings.',
    unit: 'climate',
    unitLabel: 'Climate',
    level: 'Easy Read',
    href: `${base}materials/sci6-climate-notes-ef-v1.html`,
  },
  {
    title: 'Energy Resources — Guided Notes',
    description: 'Full unit notes for Energy Resources. Renewable vs. non-renewable, before/after processing (wind used both ways), and the five selection factors (availability, societal, economic, environmental, responsible management) with an Alberta decision-making case study.',
    unit: 'energy-resources',
    unitLabel: 'Energy Resources',
    href: `${base}materials/sci6-energy-resources-notes-v1.html`,
  },
  {
    title: 'Energy Resources — Easy Read Notes',
    description: 'Easy Read version. 70/30 layout, EF reading level. Renewable vs. non-renewable, before/after processing, and the five selection factors — with vocab callouts and misconception warnings.',
    unit: 'energy-resources',
    unitLabel: 'Energy Resources',
    level: 'Easy Read',
    href: `${base}materials/sci6-energy-resources-notes-ef-v1.html`,
  },
  {
    title: 'Space — Guided Notes',
    description: 'Full unit notes for Space. Solar system components and scale, exploration technologies (telescopes, rovers, CubeSats, Ex-Alta 1), natural vs. artificial satellites, orbit mechanics, ISS life, and barriers to space exploration.',
    unit: 'space',
    unitLabel: 'Space',
    href: `${base}materials/sci6-space-notes-v1.html`,
  },
  {
    title: 'Space — Easy Read Notes',
    description: 'Easy Read version. 70/30 layout, EF reading level. Solar system objects, emit vs. reflect, scale, exploration technologies, Ex-Alta 1, ISS challenges, and Pluto reclassification — with vocab callouts and misconception warnings.',
    unit: 'space',
    unitLabel: 'Space',
    level: 'Easy Read',
    href: `${base}materials/sci6-space-notes-ef-v1.html`,
  },
];

const workbooks = [
  {
    title: 'Matter Workbook',
    description: 'Interleaved practice workbook for Matter. 30 Core and Extended questions covering all four knowledge clusters, plus Stretch Zone and self-assessment.',
    unit: 'matter',
    unitLabel: 'Matter',
    href: `${base}materials/sci6-matter-workbook-v1.html`,
  },
  {
    title: 'Forces Workbook',
    description: 'Interleaved practice workbook for the Forces unit. Core and Extended questions, retrieval across all Force concepts.',
    unit: 'forces',
    unitLabel: 'Forces',
    href: `${base}materials/sci6-forces-workbook-v1.html`,
  },
  {
    title: 'Living Systems Workbook',
    description: 'Interleaved practice workbook for Living Systems. 30 Core and Extended questions covering biotic/abiotic, photosynthesis, food webs, trophic cascades, FNMI sacred plants, and CS conditional logic.',
    unit: 'living-systems',
    unitLabel: 'Living Systems',
    href: `${base}materials/sci6-living-systems-workbook-gr6-v1.html`,
  },
  {
    title: 'Climate Workbook',
    description: 'Interleaved practice workbook for Climate. 30 Core and Extended questions covering weather vs. climate, greenhouse effect, geographic factors, albedo, natural/human causes, Alberta effects, FNMI impacts, TEK, climate models, and signal vs. noise.',
    unit: 'climate',
    unitLabel: 'Climate',
    href: `${base}materials/sci6-climate-workbook-v1.html`,
  },
  {
    title: 'Energy Resources Workbook',
    description: 'Interleaved practice workbook for Energy Resources. 24 Core and Extended questions covering renewable vs. non-renewable, before/after processing, all five selection factors, Alberta context, FNMI stewardship, and CS technology trade-offs.',
    unit: 'energy-resources',
    unitLabel: 'Energy Resources',
    href: `${base}materials/sci6-energy-resources-workbook-v1.html`,
  },
  {
    title: 'Year Review Workbook',
    description: 'End-of-year retrieval workbook spanning all six units. Interleaved questions, synthesis tasks, and self-assessment.',
    unit: 'all-units',
    unitLabel: 'All Units',
    href: `${base}materials/sci6-year-review-workbook-gr6-v1.html`,
  },
  {
    title: 'Space Workbook',
    description: 'Interleaved practice workbook for Space. 24 Core and Extended questions covering solar system objects, emit vs. reflect, scale misconceptions, exploration technologies, Ex-Alta 1, natural vs. artificial satellites, orbit mechanics, ISS, Pluto reclassification, and Indigenous sky knowledge.',
    unit: 'space',
    unitLabel: 'Space',
    href: `${base}materials/sci6-space-workbook-v1.html`,
  },
];
---

<BaseLayout title="Materials">
  <div class="mb-10">
    <p class="text-xs font-bold uppercase tracking-widest text-science-600 mb-2">Grade 6 Science</p>
    <h1 class="text-4xl font-bold text-slate-900 mb-3">Materials</h1>
    <p class="text-slate-500 text-lg max-w-xl">
      Print-ready classroom materials. Open in the browser or download to print.
    </p>
  </div>

  <!-- Notes Packages -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-4">Notes Packages</h2>
    <div class="space-y-3">
      {notes.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
                {m.level && (
                  <span class="text-xs text-slate-400 font-medium">{m.level}</span>
                )}
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Workbooks -->
  <section class="mb-12">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-4">Workbooks</h2>
    <div class="space-y-3">
      {workbooks.map(m => {
        const c = unitColors[m.unit] ?? unitColors['all-units'];
        return (
          <div class={`bg-white rounded-xl border border-slate-200 border-l-4 ${c.border} p-5 flex items-start justify-between gap-4`}>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${c.bg} ${c.text}`}>
                  {m.unitLabel}
                </span>
              </div>
              <h3 class="text-base font-bold text-slate-900 mb-1">{m.title}</h3>
              <p class="text-sm text-slate-500">{m.description}</p>
            </div>
            <a
              href={m.href}
              target="_blank"
              rel="noopener"
              class="flex-shrink-0 text-sm font-semibold text-science-700 hover:text-science-900 border border-science-300 hover:border-science-500 px-4 py-2 rounded-lg transition-colors whitespace-nowrap"
            >
              Open ↗
            </a>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
