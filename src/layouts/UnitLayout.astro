---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  tier: number;
  weeks: string;
  guidingQuestion: string;
  learningOutcome: string;
  slug: string;
  teacherMode?: boolean;
}

const { title, tier, weeks, guidingQuestion, learningOutcome, slug, teacherMode = false } = Astro.props;

const base = import.meta.env.BASE_URL;

const unitWorkbooks: Record<string, string> = {
  'matter': `${base}materials/sci6-matter-workbook-v1.html`,
  'forces': `${base}materials/sci6-forces-workbook-v1.html`,
  'living-systems': `${base}materials/sci6-living-systems-workbook-gr6-v1.html`,
  'climate': `${base}materials/sci6-climate-workbook-v1.html`,
  'energy-resources': `${base}materials/sci6-energy-resources-workbook-v1.html`,
  'space': `${base}materials/sci6-space-workbook-v1.html`,
};

const unitNotes: Record<string, string> = {
  'matter': `${base}materials/sci6-matter-notes-v1.html`,
  'living-systems': `${base}materials/sci6-living-systems-notes-gr6-v1.html`,
  'forces': `${base}materials/sci6-forces-notes-v1.html`,
  'climate': `${base}materials/sci6-climate-notes-v1.html`,
  'energy-resources': `${base}materials/sci6-energy-resources-notes-v1.html`,
  'space': `${base}materials/sci6-space-notes-v1.html`,
};

const unitNotesEF: Record<string, string> = {
  'matter': `${base}materials/sci6-matter-notes-ef-v1.html`,
  'living-systems': `${base}materials/sci6-living-systems-notes-ef-gr6-v1.html`,
  'forces': `${base}materials/sci6-forces-notes-ef-v1.html`,
  'climate': `${base}materials/sci6-climate-notes-ef-v1.html`,
  'energy-resources': `${base}materials/sci6-energy-resources-notes-ef-v1.html`,
  'space': `${base}materials/sci6-space-notes-ef-v1.html`,
};

const unitMaterialLinks = [
  ...(unitNotes[slug]   ? [{ label: 'Guided Notes',       href: unitNotes[slug],   icon: '📋' }] : []),
  ...(unitNotesEF[slug] ? [{ label: 'Notes — Easy Read',  href: unitNotesEF[slug], icon: '📄' }] : []),
  ...(unitWorkbooks[slug] ? [{ label: 'Workbook',         href: unitWorkbooks[slug], icon: '📓' }] : []),
];

const yearMaterialLinks = [
  { label: 'Year Notes',            href: `${base}materials/sci6-year-notes-v1.html`,              icon: '📋' },
  { label: 'Year Notes — Easy Read',href: `${base}materials/sci6-year-notes-ef-v1.html`,           icon: '📄' },
  { label: 'Year Review Workbook',  href: `${base}materials/sci6-year-review-workbook-gr6-v1.html`, icon: '📓' },
];

const unitColors: Record<string, { accent: string; dot: string }> = {
  'matter':           { accent: 'border-cyan-500', dot: 'bg-cyan-500' },
  'forces':           { accent: 'border-violet-500', dot: 'bg-violet-500' },
  'living-systems':   { accent: 'border-emerald-500', dot: 'bg-emerald-500' },
  'climate':          { accent: 'border-amber-500', dot: 'bg-amber-500' },
  'energy-resources': { accent: 'border-orange-500', dot: 'bg-orange-500' },
  'space':            { accent: 'border-indigo-500', dot: 'bg-indigo-500' },
};

const colors = unitColors[slug] ?? { accent: 'border-slate-400', dot: 'bg-slate-400' };
---

<BaseLayout title={title} teacherMode={teacherMode}>
  <!-- Unit header -->
  <div class={`border-l-4 ${colors.accent} pl-5 mb-8`}>
    <div class="flex items-center gap-2 mb-1">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">
        {teacherMode ? 'Teacher View · ' : ''}Grade 6 Science
      </span>
      <span class="text-xs font-semibold bg-science-100 text-science-800 px-2 py-0.5 rounded-full">
        Tier {tier} · {weeks} weeks
      </span>
    </div>
    <h1 class="text-3xl font-bold text-slate-900 mb-2">{title}</h1>
    <p class="text-slate-500 italic text-base">{guidingQuestion}</p>
  </div>

  <!-- Learning outcome -->
  <div class="bg-white rounded-xl border border-slate-200 p-4 mb-6">
    <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Learning Outcome</p>
    <p class="text-slate-700">{learningOutcome}</p>
  </div>

  <!-- Two-column: content + sidebar -->
  <div class="flex gap-6 items-start">
    <div class="flex-1 min-w-0 prose">
      <slot />
    </div>

    <!-- Sidebar -->
    <aside class="w-52 flex-shrink-0 hidden lg:block">
      <div class="sticky top-20 space-y-4">
        <!-- Materials -->
        <div class="bg-white rounded-xl border border-slate-200 p-4">
          <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">Materials</p>

          {unitMaterialLinks.length > 0 && (
            <div class="mb-3">
              <p class="text-xs font-semibold text-slate-400 mb-1.5">This unit</p>
              <nav class="space-y-0.5">
                {unitMaterialLinks.map(m => (
                  <a href={m.href} target="_blank" rel="noopener"
                    class="flex items-center gap-2 text-sm text-slate-600 hover:text-science-700 py-1 rounded transition-colors">
                    <span class="text-sm">{m.icon}</span>{m.label}
                  </a>
                ))}
              </nav>
            </div>
          )}

          <div class="border-t border-slate-100 pt-3 mb-3">
            <p class="text-xs font-semibold text-slate-400 mb-1.5">All year</p>
            <nav class="space-y-0.5">
              {yearMaterialLinks.map(m => (
                <a href={m.href} target="_blank" rel="noopener"
                  class="flex items-center gap-2 text-sm text-slate-600 hover:text-science-700 py-1 rounded transition-colors">
                  <span class="text-sm">{m.icon}</span>{m.label}
                </a>
              ))}
            </nav>
          </div>

          <div class="border-t border-slate-100 pt-3">
            <a href={`${base}materials`}
              class="text-xs font-semibold text-science-700 hover:text-science-900 transition-colors">
              All materials →
            </a>
          </div>
        </div>

        {teacherMode && (
          <div class="bg-teacher-50 rounded-xl border border-teacher-200 p-4">
            <p class="text-xs font-bold uppercase tracking-wider text-teacher-700 mb-3">Teacher Resources</p>
            <a
              href={`${base}teacher/${slug}`}
              class="text-sm text-teacher-700 hover:text-teacher-900 font-medium"
            >
              Unit Teacher Guide →
            </a>
          </div>
        )}
      </div>
    </aside>
  </div>
</BaseLayout>
